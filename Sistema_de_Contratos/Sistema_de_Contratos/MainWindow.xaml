<Window x:Class="Sistema_de_Contratos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sistema_de_Contratos"
        mc:Ignorable="d"
        Title="Sistema de Contratos" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Window.Resources>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15 10"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                    <Setter Property="Foreground" Value="#00AFB9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,6,0,6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#D7DCE3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style x:Key="PrimaryButton" BasedOn="{StaticResource MenuButton}" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#00AFB9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0081A7"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#E0E0E0"/>
                    <Setter Property="Foreground" Value="#888"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="0,56,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Border Width="380" Padding="28" CornerRadius="12" Background="White"
                    BorderBrush="#E5E9F0" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Iniciar sesión" FontSize="20" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,8"/>
                    <TextBlock Text="Ingresa tus credenciales para continuar" Foreground="#6B7280" Margin="0,0,0,8"/>

                    <TextBlock Text="Usuario" Foreground="#374151" Margin="0,6,0,2"/>
                    <TextBox x:Name="UserTextBox"/>

                    <TextBlock Text="Contraseña" Foreground="#374151" Margin="0,12,0,2"/>
                    <PasswordBox x:Name="PasswordBox"/>

                    <TextBlock x:Name="ErrorText"
                                   Foreground="#B91C1C"
                                   Margin="0,8,0,0"
                                   Visibility="Collapsed"
                                   TextWrapping="Wrap" />

                    <Button x:Name="LoginButton"
                                Style="{StaticResource PrimaryButton}"
                                Content="Ingresar"
                                Margin="0,18,0,0"
                                Click="LoginButton_Click"/>
                </StackPanel>
                
            </Border>
        </Grid>
    </Grid>

</Window>