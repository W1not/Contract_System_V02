<Window x:Class="Sistema_de_Contratos.Vistas.EditarTrabajador"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sistema_de_Contratos.Vistas"
        mc:Ignorable="d"
        Title="Editar Trabajador" 
        Height="550" 
        Width="850"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Estilos reutilizables -->
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontWeight="Bold"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Margin" Value="0 0 5 5"/>
            <Setter Property="Padding" Value="0 0 5 0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0 0 0 10"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0 0 0 10"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#00AFB9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <!-- Template mínimo esencial -->
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2">
                            <ContentPresenter x:Name="content"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0098B0"/>
                    <Setter Property="Foreground" Value="#333333"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0081A7"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <Border Grid.Row="0" Background="#00AFB9" CornerRadius="4" Padding="15" Margin="0 0 0 15">
            <TextBlock Text="Editar Datos del Trabajador" 
                       Foreground="White"
                       FontSize="16"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Contenido principal con scroll -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0 0 5 0">
            <StackPanel>
                <!-- Datos Personales -->
                <GroupBox Header="DATOS PERSONALES">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="150"/>
                            <ColumnDefinition Width="*" MinWidth="300"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Content="Nombre Completo:" Grid.Row="0" Grid.Column="0"/>
                        <TextBox x:Name="txtNombre" Grid.Row="0" Grid.Column="1"/>

                        <Label Content="CURP:" Grid.Row="1" Grid.Column="0"/>
                        <TextBox x:Name="txtCURP" Grid.Row="1" Grid.Column="1" MaxLength="18" CharacterCasing="Upper"/>

                        <Label Content="RFC:" Grid.Row="2" Grid.Column="0"/>
                        <TextBox x:Name="txtRFC" Grid.Row="2" Grid.Column="1" MaxLength="15" CharacterCasing="Upper"/>

                        <Label Content="Sexo:" Grid.Row="3" Grid.Column="0"/>
                        <ComboBox x:Name="cmbSexo" Grid.Row="3" Grid.Column="1">
                            <ComboBoxItem Content="Masculino"/>
                            <ComboBoxItem Content="Femenino"/>
                        </ComboBox>

                        <Label Content="Estado Civil:" Grid.Row="4" Grid.Column="0"/>
                        <TextBox x:Name="txtEstadoCivil" Grid.Row="4" Grid.Column="1"/>

                        <Label Content="Cédula:" Grid.Row="5" Grid.Column="0"/>
                        <TextBox x:Name="txtCedula" Grid.Row="5" Grid.Column="1"/>
                    </Grid>
                </GroupBox>

                <!-- Datos de Domicilio -->
                <GroupBox Header="DATOS DE DOMICILIO">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="150"/>
                            <ColumnDefinition Width="*" MinWidth="300"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Content="Domicilio Particular:" Grid.Row="0" Grid.Column="0"/>
                        <TextBox x:Name="txtDomicilioParticular" Grid.Row="0" Grid.Column="1"/>

                        <Label Content="Domicilio Fiscal:" Grid.Row="1" Grid.Column="0"/>
                        <TextBox x:Name="txtDomicilioFiscal" Grid.Row="1" Grid.Column="1"/>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Botones de acción -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 15 0 0" Cursor="">
            <Button x:Name="btnCancelar" Content="Cancelar" Click="btnCancelar_Click"
                    Background="Transparent" 
                    Foreground="#00AFB9"
                    BorderBrush="#00AFB9"
                    BorderThickness="1"/>

            <Button x:Name="btnGuardar" Content="Guardar Cambios" Click="btnGuardar_Click" Width="40"/>
        </StackPanel>
    </Grid>
</Window>