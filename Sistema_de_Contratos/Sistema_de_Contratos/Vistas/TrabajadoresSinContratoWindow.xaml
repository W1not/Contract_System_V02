<Window x:Class="Sistema_de_Contratos.Vistas.TrabajadoresSinContratoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trabajadores sin Contrato" Height="500" Width="850"
        WindowStartupLocation="CenterScreen" Background="#FFF9F9F9">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barra superior -->
        <Border Background="#00AFB9" Grid.Row="0" Padding="20,10" >
            <TextBlock Text="Trabajadores sin Contrato"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" Margin="10" CornerRadius="8" BorderBrush="#DDDDDD" BorderThickness="1" Background="White">
            <DataGrid x:Name="dgTrabajadores" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      SelectionMode="Single" 
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      RowHeaderWidth="0"
                      Margin="10"
                      AlternatingRowBackground="#FFF5F5F5"
                      ColumnHeaderHeight="35">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdTrabajador}" Width="Auto"/>
                    <DataGridTextColumn Header="Nombre Completo" Binding="{Binding NombreCompleto}" Width="*"/>
                    <DataGridTextColumn Header="CURP" Binding="{Binding CURP}" Width="200"/>
                    <DataGridTemplateColumn Header="Acción" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Asignar Contrato" 
                                        Click="BtnAsignarContrato_Click"
                                        Padding="6"
                                        Margin="2"
                                        Background="#00AFB9"
                                        Foreground="White"
                                        FontWeight="SemiBold"
                                        Cursor="Hand"
                                        BorderBrush="#00AFB9"
                                        BorderThickness="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
