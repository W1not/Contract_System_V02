<Window x:Class="Sistema_de_Contratos.Vistas.GestionTrabajadores"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sistema_de_Contratos.Vistas"
        mc:Ignorable="d"
        Title="Gestión de Trabajadores" 
        Height="650" 
        Width="1000"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        WindowState="Maximized">

    <Window.Resources>
        <!-- Estilos reutilizables -->
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontWeight="Bold"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#00AFB9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                Background="{TemplateBinding Background}"
                CornerRadius="2">
                            <ContentPresenter x:Name="content"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0098B0"/>
                    <Setter Property="Foreground" Value="#333333"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0081A7"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="0 0 0 15"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="RowDetailsVisibilityMode" Value="VisibleWhenSelected"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#00AFB9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8 5"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Barra superior -->
            <RowDefinition Height="Auto"/>
            <!-- Filtros -->
            <RowDefinition Height="Auto"/>
            <!-- Estadísticas -->
            <RowDefinition Height="*"/>
            <!-- Lista trabajadores -->
            <RowDefinition Height="Auto"/>
            <!-- Barra inferior -->
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <Border Grid.Row="0" Background="#00AFB9" CornerRadius="4" Padding="15" Margin="0 0 0 15">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="/Recursos/logo.png" Width="32" Height="32"/>
                <TextBlock Text="Gestion de Trabajadores" 
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="10 0 0 0"/>
            </StackPanel>
        </Border>

        <GroupBox Grid.Row="1" Header="Fltrar trabajadores">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtBuscarNombre" 
                         Grid.Column="0" 
                         Margin="0 0 10 0"
                         Padding="8"
                         KeyUp="TxtBuscar_KeyUp"
                         Tag="Buscar por nombre..."/>

                <ComboBox x:Name="cmbBuscarPuesto" 
                          Grid.Column="1" 
                          Margin="0 0 10 0"
                          DisplayMemberPath="Nombre" 
                          SelectedValuePath="IdPuesto"
                          SelectionChanged="CmbBuscarPuesto_SelectionChanged"/>

                <Button x:Name="btnLimpiarFiltros" 
                        Grid.Column="2" 
                        Content="Limpiar filtros" 
                        Click="BtnLimpiarFiltros_Click"
                        Style="{StaticResource {x:Type Button}}"/>
            </Grid>
        </GroupBox>

        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="0 0 0 1" Padding="0 0 0 10" Margin="0 0 0 15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border Background="#F5F5F5" CornerRadius="4" Padding="10 5" Margin="5">
                    <TextBlock> 
                        <Run Text="Total: " FontWeight="SemiBold"/>
                        <Run Text="{Binding ElementName=txtTotalTrabajadores, Path=Text}" Foreground="#1976D2" FontWeight="Bold"/>
                    </TextBlock>
                </Border>

                <Border Background="#E8F5E9" CornerRadius="4" Padding="10 5" Margin="5">
                    <TextBlock>
                        <Run Text="Vigentes: " FontWeight="SemiBold"/>
                        <Run Text="{Binding ElementName=txtVigentes, Path=Text}" Foreground="#2E7D32" FontWeight="Bold"/>
                    </TextBlock>
                </Border>

                <Border Background="#FFF8E1" CornerRadius="4" Padding="10 5" Margin="5">
                    <TextBlock>
                        <Run Text="Vencidos: " FontWeight="SemiBold"/>
                        <Run Text="{Binding ElementName=txtVencidos, Path=Text}" Foreground="#F57F17" FontWeight="Bold"/>
                    </TextBlock>
                </Border>

                <Border Background="#FFEBEE" CornerRadius="4" Padding="10 5" Margin="5">
                    <TextBlock>
                        <Run Text="Bajas: " FontWeight="SemiBold"/>
                        <Run Text="{Binding ElementName=txtBajas, Path=Text}" Foreground="#C62828" FontWeight="Bold"/>
                    </TextBlock>
                </Border>
            </StackPanel>
        </Border>
                <TextBlock x:Name="txtTotalTrabajadores" Visibility="Collapsed"/>
                <TextBlock x:Name="txtVigentes" Visibility="Collapsed"/>
                <TextBlock x:Name="txtVencidos" Visibility="Collapsed"/>
        <TextBlock x:Name="txtBajas" Visibility="Collapsed"/>
        
        <DataGrid x:Name="dgTrabajadores" Grid.Row="3">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding IdTrabajador}" Width="Auto" HeaderStyle="{StaticResource {x:Type DataGridColumnHeader}}"/>
                <DataGridTextColumn Header="NOMBRE COMPLETO" Binding="{Binding NombreCompleto}" Width="250"/>
                <DataGridTextColumn Header="CURP" Binding="{Binding CURP}" Width="150"/>
                <DataGridTextColumn Header="PUESTO" Binding="{Binding Puesto}" Width="250"/>
                <DataGridTextColumn Header="ESTADO" Binding="{Binding EstadoContrato}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EstadoContrato}" Value="Vigente">
                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding EstadoContrato}" Value="Vencido">
                                    <Setter Property="Foreground" Value="#F57F17"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding EstadoContrato}" Value="Baja">
                                    <Setter Property="Foreground" Value="#C62828"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="DÍAS RESTANTES" Binding="{Binding DiasRestantes}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DiasRestantes}" Value="0">
                                    <Setter Property="Foreground" Value="#C62828"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="FECHA FIN" Binding="{Binding FechaFin, StringFormat='dd/MM/yyyy'}" Width="120"/>
                <DataGridTemplateColumn Header="ACCIONES" Width="600">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Ver Detalles" 
                                        Click="btnDetalles_Click"
                                        Style="{StaticResource {x:Type Button}}"
                                        Height="25"
                                        Width="110"/>
                                <Button Content="Nuevo Contrato" 
                                        Click="btnGenerarContrato_Click"
                                        Style="{StaticResource {x:Type Button}}"
                                        Width="auto"
                                        Height="25"
                                        Margin="10,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 15 0 0">
            <Button Content="Descargar" 
                     Click="btnDescargar_Click"
                     Style="{StaticResource {x:Type Button}}"
                     Width="auto"
                     Height="25"
                     Margin="10,0,0,0"/>
            <Button x:Name="btnRegresar" 
                    Content="Cerrar" 
                    Click="BtnRegresar_Click"
                    Style="{StaticResource {x:Type Button}}"
                    Width="180"/>
        </StackPanel>
    </Grid>
</Window>