<Window x:Class="Sistema_de_Contratos.Vistas.GestionContratoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Gestión de Contrato" 
        Height="550" 
        Width="850"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Estilos reutilizables -->
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontWeight="Bold"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Margin" Value="0 0 5 5"/>
            <Setter Property="Padding" Value="0 0 5 0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0 0 0 10"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0 0 0 10"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="0 0 0 10"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#00AFB9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2">
                            <ContentPresenter x:Name="content"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0098B0"/>
                    <Setter Property="Foreground" Value="#333333"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0081A7"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#00AFB9"/>
            <Setter Property="BorderBrush" Value="#00AFB9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF5E6"/>
                    <Setter Property="Foreground" Value="#0098B0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0081A7"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <Border Grid.Row="0" Background="#00AFB9" CornerRadius="4" Padding="15" Margin="0 0 0 15">
            <TextBlock Text="Gestión de Contrato del Trabajador" 
                       Foreground="White"
                       FontSize="16"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Contenido principal con scroll -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0 0 5 0">
            <StackPanel>
                <!-- Información del Trabajador -->
                <GroupBox Header="INFORMACIÓN DEL TRABAJADOR">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{Binding NombreTrabajador}" 
                                  FontWeight="Bold" FontSize="14"
                                  Margin="0 0 0 5"/>

                        <StackPanel Orientation="Horizontal" Grid.Row="1">
                            <TextBlock Text="CURP:" FontWeight="SemiBold" Margin="0 0 5 0"/>
                            <TextBlock Text="{Binding CURP}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Grid.Row="2">
                            <TextBlock Text="Puesto actual:" FontWeight="SemiBold" Margin="0 0 5 0"/>
                            <TextBlock Text="{Binding PuestoActual}"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Datos del Contrato -->
                <GroupBox Header="DATOS DEL CONTRATO">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="150"/>
                            <ColumnDefinition Width="*" MinWidth="300"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Content="Puesto:" Grid.Row="0" Grid.Column="0"/>
                        <ComboBox x:Name="cmbPuestos" Grid.Row="0" Grid.Column="1" 
                                 DisplayMemberPath="Nombre" SelectedValuePath="IdPuesto"/>

                        <Label Content="Fecha Inicio:" Grid.Row="1" Grid.Column="0"/>
                        <DatePicker x:Name="dpFechaInicio" Grid.Row="1" Grid.Column="1"/>

                        <Label Content="Fecha Fin:" Grid.Row="2" Grid.Column="0"/>
                        <DatePicker x:Name="dpFechaFin" Grid.Row="2" Grid.Column="1"/>

                        <Label Content="Sueldo:" Grid.Row="3" Grid.Column="0"/>
                        <TextBox x:Name="txtSueldo" Grid.Row="3" Grid.Column="1"/>

                        <CheckBox x:Name="chkDarDeBaja" Grid.Row="4" Grid.Column="1" Margin="0 5"
                                 Content="Dar de baja al trabajador" FontWeight="SemiBold"/>

                        <StackPanel x:Name="pnlBaja" Grid.Row="5" Grid.Column="1" Margin="0 5 0 0" Visibility="Collapsed">
                            <Label Content="Motivo de baja:"/>
                            <TextBox x:Name="txtMotivoBaja" AcceptsReturn="True" TextWrapping="Wrap" Height="60"/>
                            <Label Content="Fecha de baja:" Margin="0 5 0 0"/>
                            <DatePicker x:Name="dpFechaBaja"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Botones de acción -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 15 0 0">
            <Button x:Name="btnRenovar" Content="Renovar Contrato" Click="btnRenovar_Click"/>
            <Button x:Name="btnGuardar" Content="Guardar Cambios" Click="btnGuardar_Click"/>
            <Button x:Name="btnCancelar" Content="Cancelar" Click="btnCancelar_Click"
                    Style="{StaticResource CancelButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>