<Window x:Class="Sistema_de_Contratos.Vistas.Legal.Home_Window"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sistema_de_Contratos"
        mc:Ignorable="d"
        Title="Sistema de Contratos" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Window.Resources>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15 10"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                    <Setter Property="Foreground" Value="#0081A7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#00AFB9" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Título -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Sistema de Contratos" 
                               Style="{StaticResource HeaderText}"
                               Margin="10 0 0 0"/>
                </StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FDFCDC" BorderThickness="0 0 1 0" BorderBrush="#E0E0E0">
                <StackPanel Margin="10">
                    <TextBlock Text="MENÚ PRINCIPAL" 
                               Foreground="#0081A7"
                               FontWeight="Bold"
                               Margin="5 15 5 5"/>

                    <Button Content="Registro de Personal" 
                            Style="{StaticResource MenuButton}"
                            Click="BtnRegistro_Click"/>

                    <Button Content="Gestión de Personal" 
                            Style="{StaticResource MenuButton}"
                            Click="BtnGestioTrabajador_Click"/>

                    <Button Content="Gestión de Puestos" 
                            Style="{StaticResource MenuButton}"
                            Click="BtnGestioPuestos_Click"/>

                    <Button Content="Trabajadores sin Contrato" 
                            Style="{StaticResource MenuButton}"
                            Click="BtnGestiosinContrato_Click"/>
                </StackPanel>
            </Border>

            <Frame x:Name="MainContentFrame" 
                   Grid.Column="1" 
                   NavigationUIVisibility="Hidden"
                   Background="White">
                <Frame.Content>
                    <Grid>
                        <Viewbox Stretch="Uniform">
                            <Image Source="pack://application:,,,/Recursos/djl_0258.jpg"
                                   Stretch="Uniform"
                                   StretchDirection="DownOnly"/>
                        </Viewbox>
                    </Grid>
                </Frame.Content>
            </Frame>
        </Grid>
    </Grid>
</Window>