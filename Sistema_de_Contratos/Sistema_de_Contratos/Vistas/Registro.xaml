<Window x:Class="Sistema_de_Contratos.Registro"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sistema_de_Contratos"
        mc:Ignorable="d"
        Title="Registro de Trabajador" 
        Height="600" 
        Width="800"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0 0 0 5"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0 0 0 10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0 0 0 10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#00AFB9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                Background="{TemplateBinding Background}"
                CornerRadius="2">
                            <ContentPresenter x:Name="content"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#008DAC"/>
                    <Setter Property="Foreground" Value="#333333"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0081A7"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <Border Grid.Row="0" Background="#00AFB9" CornerRadius="4" Padding="15" Margin="0 0 0 20">
            <TextBlock Text="Registro de Nuevo Trabajador" 
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"/>
        </Border>

        <!-- Formulario -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="200"/>
                    <ColumnDefinition Width="*" MinWidth="300"/>
                </Grid.ColumnDefinitions>

                <!-- Nombre Completo -->
                <Label Content="Nombre Completo:" Grid.Row="0" Grid.Column="0"/>
                <TextBox x:Name="txtNombreCompleto" Grid.Row="0" Grid.Column="1"/>

                <!-- Género -->
                <Label Content="Género:" Grid.Row="1" Grid.Column="0"/>
                <ComboBox x:Name="cmbGenero" Grid.Row="1" Grid.Column="1" SelectionChanged="comboGenero_SelectionChanged">
                    <ComboBoxItem Content="Masculino"/>
                    <ComboBoxItem Content="Femenino"/>
                </ComboBox>

                <!-- RFC -->
                <Label Content="RFC:" Grid.Row="2" Grid.Column="0"/>
                <TextBox x:Name="txtRFC" Grid.Row="2" Grid.Column="1" MaxLength="13" CharacterCasing="Upper"/>

                <!-- CURP -->
                <Label Content="CURP:" Grid.Row="3" Grid.Column="0"/>
                <TextBox x:Name="txtCURP" Grid.Row="3" Grid.Column="1" MaxLength="18" CharacterCasing="Upper"/>
                <!-- Evento para detectar cambios -->

                <!-- Estado Civil -->
                <Label Content="Estado Civil:" Grid.Row="5" Grid.Column="0"/>
                <ComboBox x:Name="cmbEstadoCivil" Grid.Row="5" Grid.Column="1"/>

                <!-- Domicilio Particular -->
                <Label Content="Domicilio Particular:" Grid.Row="6" Grid.Column="0"/>
                <TextBox x:Name="txtDomicilio_Particular" Grid.Row="6" Grid.Column="1"/>

                <!-- Domicilio Fiscal -->
                <Label Content="Domicilio Fiscal:" Grid.Row="7" Grid.Column="0"/>
                <TextBox x:Name="txtDomicilio_Fiscal" Grid.Row="7" Grid.Column="1"/>

                <!-- Cédula -->
                <Label Content="Cédula:" Grid.Row="8" Grid.Column="0"/>
                <TextBox x:Name="txtCedula" Grid.Row="8" Grid.Column="1"/>
            </Grid>
        </ScrollViewer>

        <!-- Botón de Registro -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 20 0 0">
            <Button Content="Registrar" 
                    Click="BtnAsignacionContrato_Click"
                    FontSize="14"/>
            
        </StackPanel>
    </Grid>
</Window>